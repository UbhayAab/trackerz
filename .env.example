# Trackerz dev/deploy environment — TEMPLATE (safe to commit)
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# You only need these for BACKEND scripts (db:push, setup:backend, deploys,
# pushing edge-function secrets). The frontend (`npm run serve`) needs NONE of
# these — the prod Supabase URL + anon key are baked into src/config.js.

# --- Supabase Management API (deploys + pushing secrets) ---
# Supabase account -> Access Tokens -> mint new (sbp_...)
SUPABASE_ACCESS_TOKEN=

# --- Supabase service-role / secret key (edge fn writes; bypasses RLS) ---
# Settings -> API -> service_role / secret key (sb_secret_...)
SB_SECRET_KEY=

# --- Database connection (db:push / migrations) — contains DB password ---
# Settings -> Database -> Connection string (URI)
SUPABASE_DB_URL=

# --- AI keys (only needed when (re)pushing edge-function secrets) ---
# These already live as edge-function secrets in Supabase; you do NOT need
# them just to run or deploy the app.
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# --- Optional / legacy ---
# Only if pointing the DeepSeek brain at an NVIDIA-hosted model.
NVIDIA_API_KEY=
